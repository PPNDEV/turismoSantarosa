rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserPublicDoc() {
      return firestore.get(
        /databases/(default)/documents/usersPublic/$(request.auth.uid)
      );
    }

    function canEditContent() {
      return isSignedIn()
        && currentUserPublicDoc().data.active == true
        && (
          currentUserPublicDoc().data.role == "administrador"
          || currentUserPublicDoc().data.role == "editor"
        );
    }

    function isAdmin() {
      return isSignedIn()
        && currentUserPublicDoc().data.active == true
        && currentUserPublicDoc().data.role == "administrador";
    }

    function isValidContentImage() {
      return request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /cms/{ownerUid}/{allPaths=**} {
      allow read: if true;
      allow write: if canEditContent()
        && (isAdmin() || ownerUid == request.auth.uid)
        && isValidContentImage();
    }

    match /cms/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidContentImage();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
