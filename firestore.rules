rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function currentUserPublicDoc() {
      return get(/databases/$(database)/documents/usersPublic/$(request.auth.uid));
    }

    function currentUserPublicExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usersPublic/$(request.auth.uid));
    }

    function isRoleAllowed(role) {
      return role in ["administrador", "editor", "visualizador"];
    }

    function hasValidPublicProfile(data) {
      return data.keys().hasOnly([
          "displayName",
          "role",
          "active",
          "createdAt",
          "updatedAt"
        ])
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 120
        && isRoleAllowed(data.role)
        && data.active is bool
        && (!("createdAt" in data) || data.createdAt is timestamp)
        && (!("updatedAt" in data) || data.updatedAt is timestamp);
    }

    function canSelfCreateRole(role) {
      return role == "visualizador"
        || (
          request.auth.token.email == "admin@santarosa.ec"
          && role == "administrador"
        )
        || (
          request.auth.token.email == "editor@santarosa.ec"
          && role == "editor"
        );
    }

    function hasValidPrivateProfile(data) {
      return data.keys().hasOnly([
          "email",
          "deletedAt",
          "createdAt",
          "updatedAt"
        ])
        && data.email is string
        && data.email.size() > 3
        && data.email.size() <= 200
        && (!("deletedAt" in data) || data.deletedAt == null || data.deletedAt is timestamp)
        && (!("createdAt" in data) || data.createdAt is timestamp)
        && (!("updatedAt" in data) || data.updatedAt is timestamp);
    }

    function isAdmin() {
      return currentUserPublicExists()
        && currentUserPublicDoc().data.active == true
        && currentUserPublicDoc().data.role == "administrador";
    }

    function canEditContent() {
      return currentUserPublicExists()
        && currentUserPublicDoc().data.active == true
        && (
          currentUserPublicDoc().data.role == "administrador"
          || currentUserPublicDoc().data.role == "editor"
        );
    }

    // =========================================================================
    // 1. COLECCIONES PRINCIPALES (Núcleo turístico)
    //    Lectura pública, escritura solo editor/admin.
    // =========================================================================

    // Actividades turísticas (RF01, RF13)
    match /actividades/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // Gastronomía local (RF02, RF13)
    match /gastronomia/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // Hospedajes disponibles (RF03, RF13)
    match /hospedajes/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // Eventos del cantón (RF04, RF13)
    match /eventos/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // Flora y fauna (RF05, RF13)
    match /flora_fauna/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // =========================================================================
    // 2. COLECCIONES DE SOPORTE E INTERACCIÓN
    // =========================================================================

    // Transporte / cooperativas (RF07)
    match /transporte/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // Galería multimedia (RF09, RF13) – URLs de Storage
    match /galeria/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // Mensajes de contacto (RF11) – Cualquier visitante puede enviar
    match /mensajes_contacto/{docId} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Encuestas de satisfacción (RF15) – Cualquier visitante puede responder
    match /encuestas_satisfaccion/{docId} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // =========================================================================
    // 3. COLECCIONES ADMINISTRATIVAS
    // =========================================================================

    // Métricas del sitio (RF09) – Lectura autenticada, escritura solo backend
    match /metricas_sitio/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Destinos turísticos (colección existente del CMS)
    match /destinos/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // Blog / noticias
    match /blog/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // Hero slides de portada
    match /heroSlides/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // Cooperativas de transporte (colección legacy / CMS)
    match /cooperativas/{docId} {
      allow read: if true;
      allow create, update, delete: if canEditContent();
    }

    // CMS principal: documento legacy – mantener acceso para migración.
    match /siteContent/{docId} {
      allow read: if docId == "main";
      allow write: if docId == "main" && canEditContent();
    }

    // Perfil público: campos visibles para cliente (incluye perfil propio).
    match /usersPublic/{userId} {
      allow list: if isAdmin();

      allow get: if isAdmin() || isOwner(userId);

      allow create: if hasValidPublicProfile(request.resource.data)
        && (
          isAdmin()
          || (
            isOwner(userId)
            && !exists(/databases/$(database)/documents/usersPublic/$(userId))
            && request.resource.data.active == true
            && canSelfCreateRole(request.resource.data.role)
          )
        );

      allow update: if hasValidPublicProfile(request.resource.data)
        && (
          isAdmin()
          || (
            isOwner(userId)
            && request.resource.data.role == resource.data.role
            && request.resource.data.active == resource.data.active
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "displayName",
              "updatedAt"
            ])
          )
        );

      allow delete: if isAdmin();
    }

    // Perfil privado: solo administración (correo, marcas de borrado, auditoría).
    match /usersPrivate/{userId} {
      allow list, get: if isAdmin();

      allow create, update: if isAdmin()
        && hasValidPrivateProfile(request.resource.data);

      allow delete: if isAdmin();
    }

    // Colección legacy bloqueada explícitamente para evitar fugas durante migración.
    match /users/{userId} {
      allow read, write: if false;
    }

    // Documento agregado de visitas. Solo lectura para usuarios autenticados.
    match /analytics/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Colecciones técnicas del contador; solo acceso por Admin SDK (Cloud Functions).
    match /analyticsSessions/{docId} {
      allow read, write: if false;
    }

    match /analyticsRouteSessions/{docId} {
      allow read, write: if false;
    }

    // Cierre por defecto: todo lo no declarado arriba se deniega.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
