// ci-test
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRoleAllowed(role) {
      return role in ["administrador", "editor", "visualizador"];
    }

    function hasValidPublicProfile(data) {
      return data.keys().hasOnly([
          "displayName",
          "role",
          "active",
          "createdAt",
          "updatedAt"
        ])
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 120
        && isRoleAllowed(data.role)
        && data.active is bool
        && (!("createdAt" in data) || data.createdAt is timestamp)
        && (!("updatedAt" in data) || data.updatedAt is timestamp);
    }

    function canSelfCreateRole(role) {
      return role == "visualizador"
        || (
          request.auth.token.email == "admin@santarosa.ec"
          && role == "administrador"
        )
        || (
          request.auth.token.email == "editor@santarosa.ec"
          && role == "editor"
        );
    }

    function hasValidPrivateProfile(data) {
      return data.keys().hasOnly([
          "email",
          "deletedAt",
          "createdAt",
          "updatedAt"
        ])
        && data.email is string
        && data.email.size() > 3
        && data.email.size() <= 200
        && (!("deletedAt" in data) || data.deletedAt == null || data.deletedAt is timestamp)
        && (!("createdAt" in data) || data.createdAt is timestamp)
        && (!("updatedAt" in data) || data.updatedAt is timestamp);
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.role == "administrador";
    }

    function canEditContent() {
      return request.auth != null && request.auth.token.role in ["administrador", "editor"];
    }

    function isEditor() {
      return request.auth != null && request.auth.token.role == "editor";
    }

    function canCreateOwnedContent() {
      return isAdmin()
        || (
          isEditor()
          && request.resource.data.ownerUid == request.auth.uid
        );
    }

    function canUpdateOwnedContent() {
      return isAdmin()
        || (
          isEditor()
          && resource.data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == resource.data.ownerUid
        );
    }

    function canDeleteOwnedContent() {
      return isAdmin()
        || (
          isEditor()
          && resource.data.ownerUid == request.auth.uid
        );
    }

    function hasValidReview(data) {
      return data.keys().hasOnly([
          "nombre",
          "cedula",
          "tipoObjetivo",
          "objetivoId",
          "objetivoNombre",
          "isla",
          "calificacion",
          "opinion",
          "estado",
          "fecha"
        ])
        && data.nombre is string
        && data.nombre.size() > 0
        && data.nombre.size() <= 80
        && data.cedula is string
        && data.cedula.matches('^[0-9]{10}$')
        && data.tipoObjetivo in ["isla", "establecimiento", "atractivo"]
        && data.objetivoId is string
        && data.objetivoId.size() > 0
        && data.objetivoId.size() <= 140
        && data.objetivoNombre is string
        && data.objetivoNombre.size() > 0
        && data.objetivoNombre.size() <= 120
        && data.isla is string
        && data.isla.size() > 0
        && data.isla.size() <= 80
        && data.calificacion is int
        && data.calificacion >= 1
        && data.calificacion <= 5
        && data.opinion is string
        && data.opinion.size() >= 10
        && data.opinion.size() <= 600
        && data.estado == "pendiente"
        && data.fecha == request.time;
    }

    // =========================================================================
    // 1. COLECCIONES PRINCIPALES (Núcleo turístico)
    //    Lectura pública, escritura solo editor/admin.
    // =========================================================================

    // Actividades turísticas (RF01, RF13)
    match /actividades/{docId} {
      allow read: if true;
      allow create: if canCreateOwnedContent();
      allow update: if canUpdateOwnedContent();
      allow delete: if canDeleteOwnedContent();
    }

    // Gastronomía local (RF02, RF13)
    match /gastronomia/{docId} {
      allow read: if true;
      allow create: if canCreateOwnedContent();
      allow update: if canUpdateOwnedContent();
      allow delete: if canDeleteOwnedContent();
    }

    // Hospedajes disponibles (RF03, RF13)
    match /hospedajes/{docId} {
      allow read: if true;
      allow create: if canCreateOwnedContent();
      allow update: if canUpdateOwnedContent();
      allow delete: if canDeleteOwnedContent();
    }

    // Eventos del cantón (RF04, RF13)
    match /eventos/{docId} {
      allow read: if true;
      allow create: if canCreateOwnedContent();
      allow update: if canUpdateOwnedContent();
      allow delete: if canDeleteOwnedContent();
    }

    // Flora y fauna (RF05, RF13)
    match /flora_fauna/{docId} {
      allow read: if true;
      allow create: if canCreateOwnedContent();
      allow update: if canUpdateOwnedContent();
      allow delete: if canDeleteOwnedContent();
    }

    // =========================================================================
    // 2. COLECCIONES DE SOPORTE E INTERACCIÓN
    // =========================================================================

    // Transporte / cooperativas (RF07)
    match /transporte/{docId} {
      allow read: if true;
      allow create: if canCreateOwnedContent();
      allow update: if canUpdateOwnedContent();
      allow delete: if canDeleteOwnedContent();
    }

    // Galería multimedia (RF09, RF13) – URLs de Storage
    match /galeria/{docId} {
      allow read: if true;
      allow create: if canCreateOwnedContent();
      allow update: if canUpdateOwnedContent();
      allow delete: if canDeleteOwnedContent();
    }

    // Mensajes de contacto (RF11) – Cualquier visitante puede enviar
    match /mensajes_contacto/{docId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // Encuestas de satisfacción (RF15) – Cualquier visitante puede responder
    match /encuestas_satisfaccion/{docId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // Reseñas turisticas (RF18): visitantes crean, administrador modera.
    match /resenas_turisticas/{docId} {
      allow get, list: if isSignedIn() || resource.data.estado == "aprobada";
      allow create: if hasValidReview(request.resource.data);
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["estado"])
        && request.resource.data.estado in ["pendiente", "aprobada", "rechazada"];
      allow delete: if isAdmin();
    }

    // Bandeja de entrada para solicitudes de negocios nuevos
    match /solicitudes_negocios/{docId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.auth != null;
    }

    // Solicitudes de registro de editores (RF-EDI-01). Se crean y moderan
    // exclusivamente desde Cloud Functions (Admin SDK); el panel solo lee.
    match /solicitudes_editores/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }


    // =========================================================================
    // 3. COLECCIONES ADMINISTRATIVAS
    // =========================================================================

    // Configuración global del sitio (Mascotas, etc.)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Métricas del sitio (RF09) – Lectura autenticada, escritura solo backend
    match /metricas_sitio/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Hero slides de portada
    match /heroSlides/{docId} {
      allow read: if true;
      allow create: if canCreateOwnedContent();
      allow update: if canUpdateOwnedContent();
      allow delete: if canDeleteOwnedContent();
    }

    // Cooperativas de transporte (colección legacy / CMS)
    match /cooperativas/{docId} {
      allow read: if true;
      allow create: if canCreateOwnedContent();
      allow update: if canUpdateOwnedContent();
      allow delete: if canDeleteOwnedContent();
    }

    // CMS principal: documento legacy – mantener acceso para migración.
    match /siteContent/{docId} {
      allow read: if docId == "main";
      allow write: if docId == "main" && canEditContent();
    }

    // Perfil público: campos visibles para cliente (incluye perfil propio).
    match /usersPublic/{userId} {
      allow list: if isAdmin();

      allow get: if isAdmin() || isOwner(userId);

      allow create: if hasValidPublicProfile(request.resource.data)
        && (
          isAdmin()
          || (
            isOwner(userId)
            && !exists(/databases/$(database)/documents/usersPublic/$(userId))
            && request.resource.data.active == true
            && canSelfCreateRole(request.resource.data.role)
          )
        );

      allow update: if hasValidPublicProfile(request.resource.data)
        && (
          isAdmin()
          || (
            isOwner(userId)
            && request.resource.data.role == resource.data.role
            && request.resource.data.active == resource.data.active
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "displayName",
              "updatedAt"
            ])
          )
        );

      allow delete: if isAdmin();
    }

    // Perfil privado: solo administración (correo, marcas de borrado, auditoría).
    match /usersPrivate/{userId} {
      allow list, get: if isAdmin();

      allow create, update: if isAdmin()
        && hasValidPrivateProfile(request.resource.data);

      allow delete: if isAdmin();
    }

    // Colección legacy bloqueada explícitamente para evitar fugas durante migración.
    match /users/{userId} {
      allow read, write: if false;
    }

    // Documento agregado de visitas. Solo lectura para usuarios autenticados.
    match /analytics/{docId} {
      allow read: if docId == "traffic" || isSignedIn();
      allow write: if false;
    }

    // Colecciones técnicas del contador; solo acceso por Admin SDK (Cloud Functions).
    match /analyticsSessions/{docId} {
      allow read, write: if false;
    }

    match /analyticsRouteSessions/{docId} {
      allow read, write: if false;
    }

    // Cierre por defecto: todo lo no declarado arriba se deniega.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
