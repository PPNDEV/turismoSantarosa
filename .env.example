# Firebase Configuration
# Copia este archivo como .env y llena con tus valores reales.
# No subas archivos .env con credenciales reales a GitHub.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

VITE_VISITS_API_URL=
VITE_VISITS_BACKEND_MODE=
VITE_VISITS_ALLOW_DIRECT_FALLBACK=
VITE_FIREBASE_FUNCTIONS_PROJECT_ID=

# Formularios publicos
VITE_CONTACT_API_URL=
VITE_SURVEY_API_URL=

# Auth
VITE_AUTH_FORCE_FIREBASE=

# Solo desarrollo local con emulador de Functions
VITE_USE_FUNCTIONS_EMULATOR=
