# Firebase Configuration
# Copia este archivo como .env y llena con tus valores reales
# NUNCA subas el archivo .env a GitHub

VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto
VITE_FIREBASE_DATABASE_URL=https://tu_proyecto-default-rtdb.firebaseio.com
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Visitas (recomendado: Cloud Function)
VITE_VISITS_API_URL=/api/visits
VITE_VISITS_BACKEND_MODE=function
VITE_VISITS_ALLOW_DIRECT_FALLBACK=false

# Auth (recomendado: forzar Firebase en produccion)
VITE_AUTH_FORCE_FIREBASE=true

# Solo desarrollo local con emulador de Functions
# VITE_FIREBASE_FUNCTIONS_PROJECT_ID=tu_proyecto
# VITE_USE_FUNCTIONS_EMULATOR=true
